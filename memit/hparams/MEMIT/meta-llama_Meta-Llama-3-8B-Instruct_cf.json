{
    "_note": "CF-optimized MEMIT hyperparameters for LLaMA-3-8B-Instruct. Key changes: lower kl_factor for better paraphrase泛化, higher clamp_norm for stronger edits, more grad steps for convergence, lower weight_decay for stable training.",
    "layers": [4, 5, 6, 7, 8],
    "layer_selection": "all",
    "fact_token": "subject_last",
    "v_num_grad_steps": 50,
    "v_lr": 5e-1,
    "v_loss_layer": 31,
    "v_weight_decay": 0.3,
    "clamp_norm_factor": 1.0,
    "kl_factor": 0.02,
    "mom2_adjustment": true,
    "mom2_update_weight": 20000,
    "rewrite_module_tmp": "model.layers.{}.mlp.down_proj",
    "layer_module_tmp": "model.layers.{}",
    "mlp_module_tmp": "model.layers.{}.mlp",
    "attn_module_tmp": "model.layers.{}.self_attn",
    "ln_f_module": "model.norm",
    "lm_head_module": "lm_head",
    "mom2_dataset": "wikipedia",
    "mom2_n_samples": 100000,
    "mom2_dtype": "float32",
    "mom2_batch_tokens": 2048
}
